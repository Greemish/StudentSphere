<?xml version="1.0" encoding="UTF-8"?>
<web-app version="6.0" xmlns="https://jakarta.ee/xml/ns/jakartaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd">
    <!-- Student Servlets -->
    <servlet>
        <servlet-name>SignupServlet</servlet-name>
        <servlet-class>student.SignupServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>StudentLoginServlet</servlet-name>
        <servlet-class>student.StudentLoginServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>DashboardServlet</servlet-name>
        <servlet-class>student.DashboardServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ModuleMessagesServlet</servlet-name>
        <servlet-class>student.ModuleMessagesServlet</servlet-class>
    </servlet>
    <!-- Lecturer Servlets - Keeping only the ones with two t's (Servlett) -->
    <servlet>
        <servlet-name>lecturerLoginServlett</servlet-name>
        <servlet-class>lecturer.lecturerLoginServlett</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>LectureDashboardServlett</servlet-name>
        <servlet-class>lecturer.LectureDashboardServlett</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ModuleContentServlett</servlet-name>
        <servlet-class>lecturer.ModuleContentServlett</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>UploadContentServlett</servlet-name>
        <servlet-class>lecturer.UploadContentServlett</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>DeleteContentServlett</servlet-name>
        <servlet-class>lecturer.DeleteContentServlett</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>CreateAnnouncementServlet</servlet-name>
        <servlet-class>lecturer.CreateAnnouncementServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>LecturerMessagesServlet</servlet-name>
        <servlet-class>lecturer.LecturerMessagesServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ModuleHomeServlet</servlet-name>
        <servlet-class>lecturer.ModuleHomeServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ViewStudentsServlet</servlet-name>
        <servlet-class>lecturer.ViewStudentsServlet</servlet-class>
    </servlet>
    <!-- Student Servlet Mappings -->
    <servlet-mapping>
        <servlet-name>SignupServlet</servlet-name>
        <url-pattern>/SignupServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>StudentLoginServlet</servlet-name>
        <url-pattern>/StudentLoginServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>DashboardServlet</servlet-name>
        <url-pattern>/DashboardServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ModuleMessagesServlet</servlet-name>
        <url-pattern>/ModuleMessagesServlet</url-pattern>
    </servlet-mapping>
    <!-- Lecturer Servlet Mappings - All with two t's -->
    <servlet-mapping>
        <servlet-name>lecturerLoginServlett</servlet-name>
        <url-pattern>/lecturerLoginServlett</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>LectureDashboardServlett</servlet-name>
        <url-pattern>/LectureDashboardServlett</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ModuleContentServlett</servlet-name>
        <url-pattern>/ModuleContentServlett</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>UploadContentServlett</servlet-name>
        <url-pattern>/UploadContentServlett</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>DeleteContentServlett</servlet-name>
        <url-pattern>/DeleteContentServlett</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>CreateAnnouncementServlet</servlet-name>
        <url-pattern>/CreateAnnouncementServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>LecturerMessagesServlet</servlet-name>
        <url-pattern>/LecturerMessagesServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ModuleHomeServlet</servlet-name>
        <url-pattern>/ModuleHomeServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ViewStudentsServlet</servlet-name>
        <url-pattern>/ViewStudentsServlet</url-pattern>
    </servlet-mapping>
    <!-- Welcome Page -->
    <welcome-file-list>
        <welcome-file>login.jsp</welcome-file>
    </welcome-file-list>
</web-app>
